<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

  <display-name>hospital-webapp</display-name>
  
  <!-- Global Application Parameters (ServletContext) -->
  <context-param>
    <param-name>globalAdminKey</param-name>
    <param-value>SanityAdmin2026</param-value>
  </context-param>
  <context-param>
    <param-name>hospitalCity</param-name>
    <param-value>Nairobi, Kenya</param-value>
  </context-param>
  <context-param>
    <param-name>hospitalEmail</param-name>
    <param-value>support@sanitycare.info</param-value>
  </context-param>

  <!-- ============================================================ -->
  <!--  FILTER 1: LoggingFilter — Logs every request & response     -->
  <!--  Runs FIRST in the filter chain.                            -->
  <!-- ============================================================ -->
  <filter>
    <filter-name>LoggingFilter</filter-name>
    <filter-class>com.example.LoggingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>LoggingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- ============================================================ -->
  <!--  FILTER 2: AuthenticationFilter — Enforces login for         -->
  <!--  protected routes. Runs SECOND in the filter chain.          -->
  <!-- ============================================================ -->
  <filter>
    <filter-name>AuthenticationFilter</filter-name>
    <filter-class>com.example.AuthenticationFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthenticationFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- ============================================================ -->
  <!--  WAY 1: HomeServlet — directly implements the Servlet        -->
  <!--          interface. We must override all 5 methods.          -->
  <!--  URL: /home                                                  -->
  <!-- ============================================================ -->
  <servlet>
          <servlet-name>HomeServlet</servlet-name>
          <servlet-class>com.example.HomeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  WAY 2: ServicesServlet — extends GenericServlet.            -->
  <!--          Only service() must be overridden.                  -->
  <!--  URL: /services                                              -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>ServicesServlet</servlet-name>
    <servlet-class>com.example.ServicesServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ServicesServlet</servlet-name>
    <url-pattern>/services</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  WAY 3: BookAppointmentServlet — extends HttpServlet.        -->
  <!--          doGet()  → shows the appointment form               -->
  <!--          doPost() → processes the form and shows confirmation-->
  <!--  URL: /appointment                                           -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>BookAppointmentServlet</servlet-name>
    <servlet-class>com.example.BookAppointmentServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BookAppointmentServlet</servlet-name>
    <url-pattern>/appointment</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  RegisterServlet — Demonstrates ServletConfig (init-param)   -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.example.RegisterServlet</servlet-class>
    <init-param>
      <param-name>registrationSecret</param-name>
      <param-value>Sanity2026</param-value>
    </init-param>
    <init-param>
      <param-name>pageName</param-name>
      <param-value>Staff Registration | SanityCare</param-value>
    </init-param>
    <init-param>
      <param-name>pageHeader</param-name>
      <param-value>Hospital Staff Enrollment</param-value>
    </init-param>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  ConfirmationServlet — Demonstrates RequestDispatcher.forward() -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>ConfirmationServlet</servlet-name>
    <servlet-class>com.example.ConfirmationServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ConfirmationServlet</servlet-name>
    <url-pattern>/confirmation</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  NoticeServlet — Demonstrates RequestDispatcher.include()    -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>NoticeServlet</servlet-name>
    <servlet-class>com.example.NoticeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NoticeServlet</servlet-name>
    <url-pattern>/notice</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  FooterServlet — Trainer's pattern for shared UI components  -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>FooterServlet</servlet-name>
    <servlet-class>com.example.FooterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>FooterServlet</servlet-name>
    <url-pattern>/footer</url-pattern>
  </servlet-mapping>

  <!-- ============================================================ -->
  <!--  HttpSession Authentication                                  -->
  <!-- ============================================================ -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.example.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.example.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>StaffListServlet</servlet-name>
    <servlet-class>com.example.StaffListServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>StaffListServlet</servlet-name>
    <url-pattern>/staff</url-pattern>
  </servlet-mapping>

</web-app>
